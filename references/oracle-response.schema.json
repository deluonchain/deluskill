{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/deluonchain/deluskill/blob/main/references/oracle-response.schema.json",
  "title": "DeluOracleResponse",
  "description": "v29-tiered-flywheel response shape returned by the delu-oracle x402 endpoint. Leads with a flat decision header; observed block (market/regime/social + scout/auditor/quant mirror) is always included in the default response — no ?verbose=true required.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision",
    "ca",
    "chain",
    "score",
    "verdict",
    "confidence",
    "drivers",
    "risks",
    "signals",
    "context",
    "mandate",
    "observed",
    "selected_timeframe",
    "pool_source",
    "candle_count",
    "timestamp",
    "oracle_version"
  ],
  "properties": {
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "conviction", "direction", "entry_low", "entry_high", "stop", "size_pct", "read"],
      "properties": {
        "action": { "enum": ["ENTER", "WATCH", "AVOID"] },
        "conviction": { "type": "number", "minimum": 0, "maximum": 100 },
        "direction": { "const": "long" },
        "entry_low": { "type": ["number", "null"] },
        "entry_high": { "type": ["number", "null"] },
        "stop": { "type": ["number", "null"] },
        "size_pct": { "type": ["number", "null"] },
        "read": { "type": "string" }
      }
    },
    "ca": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" },
    "chain": { "const": "base" },
    "score": { "type": "number", "minimum": 0, "maximum": 100 },
    "verdict": {
      "type": "string",
      "enum": ["strong_buy", "buy", "hold", "avoid", "drop"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "drivers": { "type": "array", "items": { "type": "string" }, "maxItems": 3 },
    "risks": { "type": "array", "items": { "type": "string" }, "maxItems": 3 },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["momentum", "flow", "structure", "volatility", "liquidity"],
      "properties": {
        "momentum": {
          "type": "object",
          "additionalProperties": false,
          "required": ["h1_aligned_with_h24", "direction", "strength"],
          "properties": {
            "h1_aligned_with_h24": { "type": "boolean" },
            "direction": { "enum": ["bullish", "bearish", "neutral"] },
            "strength": { "enum": ["strong", "moderate", "weak"] }
          }
        },
        "flow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["buyer_pressure", "net_flow_h1_pct", "txn_intensity", "data_quality"],
          "properties": {
            "buyer_pressure": { "enum": ["dominant", "balanced", "weak", "unknown"] },
            "net_flow_h1_pct": { "type": "number" },
            "txn_intensity": { "enum": ["high", "normal", "low"] },
            "data_quality": { "enum": ["full", "estimated"] }
          }
        },
        "structure": {
          "type": "object",
          "additionalProperties": false,
          "required": ["state", "bias"],
          "properties": {
            "state": { "enum": ["accumulation", "markup", "distribution", "markdown", "mixed"] },
            "bias": { "enum": ["bullish", "bearish", "neutral"] }
          }
        },
        "volatility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["regime", "atr_pct_1h", "atr_pct_band"],
          "properties": {
            "regime": { "enum": ["low", "normal", "elevated", "extreme"] },
            "atr_pct_1h": { "type": ["number", "null"] },
            "atr_pct_band": { "enum": ["p0-p25", "p25-p50", "p50-p75", "p75-p100"] }
          }
        },
        "liquidity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["depth_tier", "liquidity_to_volume_ratio"],
          "properties": {
            "depth_tier": { "enum": ["thin", "moderate", "deep", "premium"] },
            "liquidity_to_volume_ratio": { "type": "number" }
          }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["regime_label", "regime_confidence", "base_eco_pulse", "macro_pulse"],
      "properties": {
        "regime_label": {
          "type": "string",
          "enum": ["BASE_DECOUPLED", "BULL_TREND", "BULL_CHOP", "MIXED", "BEAR_TREND", "BEAR_CAPITULATION", "DEAD"]
        },
        "regime_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "base_eco_pulse": { "enum": ["expanding", "contracting", "flat"] },
        "macro_pulse": { "enum": ["supportive", "neutral", "headwind"] }
      }
    },
    "mandate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "entry_zone",
        "stop_loss",
        "stop_basis",
        "size_hint_pct",
        "size_basis",
        "horizon",
        "invalidations"
      ],
      "properties": {
        "action": { "enum": ["ENTER", "WATCH", "AVOID"] },
        "entry_zone": {
          "type": ["array", "null"],
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "stop_loss": { "type": ["number", "null"] },
        "stop_basis": { "type": ["string", "null"] },
        "size_hint_pct": { "type": ["number", "null"] },
        "size_basis": { "type": ["string", "null"] },
        "horizon": { "type": "string" },
        "invalidations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "observed": {
      "type": "object",
      "description": "Always present in the default response. No ?verbose=true required. Raw market block + deluagent scout/auditor/quant mirror + regime + social.",
      "additionalProperties": true,
      "properties": {
        "market": {
          "type": "object",
          "description": "Raw price, liquidity, volume, ATR, pool age, dex.",
          "additionalProperties": true
        },
        "regime": {
          "type": "object",
          "description": "Regime classification inputs and outputs.",
          "additionalProperties": true
        },
        "social": {
          "type": "object",
          "description": "Social signal. { status: 'unavailable' } when ?social=true not passed.",
          "additionalProperties": true
        },
        "deluagent": {
          "type": "object",
          "description": "Scout/auditor/quant mirror with weights_used.",
          "additionalProperties": true,
          "properties": {
            "scout": { "type": "object", "additionalProperties": true },
            "auditor": { "type": "object", "additionalProperties": true },
            "quant": { "type": "object", "additionalProperties": true }
          }
        }
      }
    },
    "summary": {
      "type": "string",
      "description": "Pre-lint narrative; source of decision.read before voice guardrails."
    },
    "selected_timeframe": { "type": ["string", "null"], "enum": ["1h", "15m", "5m", null] },
    "pool_source": { "enum": ["primary", "gecko_alt_pool"] },
    "candle_count": { "type": "number", "minimum": 0 },
    "timestamp": { "type": "string", "format": "date-time" },
    "oracle_version": { "const": "v29-tiered-flywheel" }
  }
}
