{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/deluonchain/deluskill/blob/main/references/oracle-response.schema.json",
  "title": "DeluOracleResponse",
  "description": "v2-full-cognition response shape returned by the delu-oracle x402 endpoint.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ca",
    "chain",
    "score",
    "verdict",
    "confidence",
    "summary",
    "drivers",
    "risks",
    "observed",
    "signals",
    "context",
    "comparables",
    "mandate",
    "timestamp",
    "oracle_version"
  ],
  "properties": {
    "ca": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" },
    "chain": { "const": "base" },
    "score": { "type": "number", "minimum": 0, "maximum": 100 },
    "verdict": {
      "type": "string",
      "enum": ["strong_buy", "buy", "hold", "avoid", "drop"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "summary": { "type": "string" },
    "drivers": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "observed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["market", "regime", "social"],
      "properties": {
        "market": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "liquidity_usd",
            "volume_h1",
            "volume_h24",
            "price_change_h1",
            "price_change_h24",
            "atr_pct_1h",
            "pool_age_days"
          ],
          "properties": {
            "liquidity_usd": { "type": "number" },
            "volume_h1": { "type": "number" },
            "volume_h24": { "type": "number" },
            "price_change_h1": { "type": "number" },
            "price_change_h24": { "type": "number" },
            "atr_pct_1h": { "type": ["number", "null"] },
            "pool_age_days": { "type": ["number", "null"] }
          }
        },
        "regime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "confidence"],
          "properties": {
            "label": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "social": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "const": "not_returned_raw" }
          }
        }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["momentum", "flow", "structure", "volatility", "liquidity"],
      "properties": {
        "momentum": {
          "type": "object",
          "additionalProperties": false,
          "required": ["h1_aligned_with_h24", "direction", "strength"],
          "properties": {
            "h1_aligned_with_h24": { "type": "boolean" },
            "direction": { "enum": ["bullish", "bearish", "neutral"] },
            "strength": { "enum": ["strong", "moderate", "weak"] }
          }
        },
        "flow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["buyer_pressure", "net_flow_h24_pct", "txn_intensity", "data_quality"],
          "properties": {
            "buyer_pressure": { "enum": ["dominant", "balanced", "weak", "unknown"] },
            "net_flow_h24_pct": { "type": "number" },
            "txn_intensity": { "enum": ["high", "normal", "low"] },
            "data_quality": { "enum": ["full", "estimated"] }
          }
        },
        "structure": {
          "type": "object",
          "additionalProperties": false,
          "required": ["state", "bias"],
          "properties": {
            "state": { "enum": ["accumulation", "markup", "distribution", "markdown", "mixed"] },
            "bias": { "enum": ["bullish", "bearish", "neutral"] }
          }
        },
        "volatility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["regime", "atr_pct_1h", "atr_pct_band"],
          "properties": {
            "regime": { "enum": ["low", "normal", "elevated", "extreme"] },
            "atr_pct_1h": { "type": ["number", "null"] },
            "atr_pct_band": { "enum": ["p0-p25", "p25-p50", "p50-p75", "p75-p100"] }
          }
        },
        "liquidity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["depth_tier", "liquidity_to_volume_ratio"],
          "properties": {
            "depth_tier": { "enum": ["thin", "moderate", "deep", "premium"] },
            "liquidity_to_volume_ratio": { "type": "number" }
          }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_eco_pulse", "macro_pulse", "pool_age_tier"],
      "properties": {
        "base_eco_pulse": { "enum": ["expanding", "contracting", "flat"] },
        "macro_pulse": { "enum": ["supportive", "neutral", "headwind"] },
        "pool_age_tier": { "enum": ["fresh", "young", "mature", "veteran"] }
      }
    },
    "comparables": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol", "relation"],
        "properties": {
          "symbol": { "type": "string" },
          "relation": { "type": "string" }
        }
      }
    },
    "mandate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "entry_zone",
        "stop_loss",
        "stop_basis",
        "size_hint_pct",
        "size_basis",
        "horizon",
        "invalidation"
      ],
      "properties": {
        "action": { "enum": ["enter", "watch", "avoid"] },
        "entry_zone": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["low", "high"],
          "properties": {
            "low": { "type": "number" },
            "high": { "type": "number" }
          }
        },
        "stop_loss": { "type": ["number", "null"] },
        "stop_basis": { "type": "string" },
        "size_hint_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "size_basis": { "type": "string" },
        "horizon": { "type": "string" },
        "invalidation": { "type": "string" }
      }
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "oracle_version": { "const": "v2-full-cognition" }
  }
}
